# ==============================================================================
# WiperX — .gitignore
# ==============================================================================

# ── Виртуальное окружение ─────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Python-кэш ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pycache

# ── Сборка / дистрибуция ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ── Тесты и покрытие ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE и редакторы ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Логи ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Рабочие артефакты WiperX ──────────────────────────────────────────────────
# Результаты анализа (генерируются в runtime, не хранятся в репо)
output/
reports/
temp/
tmp/
*.json.out

# ── Образы и монтированные точки ─────────────────────────────────────────────
*.img
*.dd
*.e01
*.vmdk
*.iso
mnt/

# ── Чувствительные данные ─────────────────────────────────────────────────────
.env
*.key
*.pem
*.crt
secrets.yaml
secrets.yml

# ── Прочее ───────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
.cache/
